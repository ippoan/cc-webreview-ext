{
  "manifest_version": 3,
  "name": "cc-webreview",
  "version": "0.0.1",
  "description": "draft PR のブラウザ込みレビューを claude (native host 経由) で回す side panel 拡張",
  "key": "",
  "permissions": ["nativeMessaging", "sidePanel"],
  "host_permissions": ["https://ci-dashboard.ippoan.org/*"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "cc-webreview"
  },
  "background": {
    "service_worker": "background.js"
  }
}
